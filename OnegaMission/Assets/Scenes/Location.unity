--- !u!1001 &1684710424
PrefabInstance:
  m_ObjectHideFlags: 0
  serializedVersion: 2
  m_Modification:
    serializedVersion: 3
    m_TransformParent: {fileID: 771902046}
    m_Modifications:
    - target: {fileID: -5180779339246638663, guid: 5468e3b87c9f14dd99e84edbb241766a, type: 3}
      propertyPath: _lore
      value: "\u0412\u0441\u0451, \u0447\u0442\u043E \u0442\u0435\u0440\u044F\u044E\u0442
        \u043B\u044E\u0434\u0438 \u0432 \u0411\u0435\u043B\u043E\u043C \u043C\u043E\u0440\u0435
        \u2014 \u0431\u0443\u0442\u044B\u043B\u043A\u0438, \u0442\u0440\u044F\u043F\u043A\u0438,
        \u043E\u0431\u043B\u043E\u043C\u043A\u0438 \u2014 \u043D\u0435 \u0442\u043E\u043D\u0435\u0442,
        \u0430 \u0441\u043E\u0431\u0438\u0440\u0430\u0435\u0442\u0441\u044F \u0432
        \u043F\u043B\u0430\u0432\u0430\u044E\u0449\u0438\u0435 \u043E\u0441\u0442\u0440\u043E\u0432\u0430.
        \u042D\u0442\u043E\u0442 \u043C\u0443\u0441\u043E\u0440 \u043E\u0436\u0438\u043B
        \u0438 \u0441\u0442\u0430\u043B \u0440\u0430\u0437\u0443\u043C\u043D\u044B\u043C.
        \u041E\u043D \u0437\u0430\u0432\u0438\u0434\u0443\u0435\u0442 \u0442\u0435\u043C,
        \u043A\u0442\u043E \u0446\u0435\u043B (\u043A\u0430\u043A \u0428\u0438\u043D\u0430),
        \u0438 \u043F\u044B\u0442\u0430\u0435\u0442\u0441\u044F \u043F\u0440\u0438\u0442\u044F\u043D\u0443\u0442\u044C
        \u043A \u0441\u0435\u0431\u0435 \u0432\u0441\u0451 \u0436\u0438\u0432\u043E\u0435."
      objectReference: {fileID: 0}
    - target: {fileID: -5180779339246638663, guid: 5468e3b87c9f14dd99e84edbb241766a, type: 3}
      propertyPath: _itemName
      value: "\u0428\u0438\u043D\u0430"
      objectReference: {fileID: 0}
    - target: {fileID: -5180779339246638663, guid: 5468e3b87c9f14dd99e84edbb241766a, type: 3}
      propertyPath: _itemType
      value: 
      objectReference: {fileID: 11400000, guid: 0592013ee7a9447c7a28999711abae26, type: 2}
    - target: {fileID: -5180779339246638663, guid: 5468e3b87c9f14dd99e84edbb241766a, type: 3}
      propertyPath: _description
      value: "\u0427\u0451\u0440\u043D\u0430\u044F \u0430\u0432\u0442\u043E\u043C\u043E\u0431\u0438\u043B\u044C\u043D\u0430\u044F
        \u043F\u043E\u043A\u0440\u044B\u0448\u043A\u0430, \u043D\u0430\u043F\u043E\u043B\u043E\u0432\u0438\u043D\u0443
        \u0441\u043A\u0440\u044B\u0442\u0430\u044F \u043F\u043E\u0434 \u043B\u044C\u0434\u043E\u043C.
        \u0418\u0437\u043D\u0443\u0442\u0440\u0438 \u0441\u0432\u0435\u0442\u0438\u0442\u0441\u044F
        \u0442\u0443\u0441\u043A\u043B\u044B\u043C \u0441\u0432\u0435\u0442\u043E\u043C
        \u2014 \u0431\u0443\u0434\u0442\u043E \u0434\u0443\u0448\u0430 \u0443 \u043C\u0430\u0448\u0438\u043D\u044B
        \u043E\u0441\u0442\u0430\u043B\u0430\u0441\u044C. \u0412\u043E\u043A\u0440\u0443\u0433
        \u043D\u0435\u0451 \u0432\u0441\u0435\u0433\u0434\u0430 \u0447\u0438\u0441\u0442\u043E
        \u2014 \u043C\u0443\u0441\u043E\u0440 \u043D\u0435 \u043F\u0440\u0438\u0441\u0442\u0430\u0451\u0442."
      objectReference: {fileID: 0}
    - target: {fileID: 2689887545016693026, guid: 5468e3b87c9f14dd99e84edbb241766a, type: 3}
      propertyPath: m_Name
      value: Wheel_2
      objectReference: {fileID: 0}

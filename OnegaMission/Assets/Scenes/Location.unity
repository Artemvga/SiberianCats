  _itemType: "\u041B\u043E\u0432\u0443\u0448\u043A\u0430"
  _description: "\u041A\u0442\u043E-\u0442\u043E \u0437\u0430\u043F\u0443\u0442\u0430\u043B\u0441\u044F
    \u0432 \u043C\u0443\u0441\u043E\u0440\u0435. \u041D\u0443\u0436\u043D\u044B \u043D\u043E\u0436\u043D\u0438\u0446\u044B!"
  _lore: "\u0411\u0435\u0434\u043D\u044B\u0439, \u0431\u0435\u0441\u043F\u043E\u043C\u043E\u0449\u043D\u044B\u0439
    \u0434\u0435\u0442\u0451\u043D\u044B\u0448 \u0442\u044E\u043B\u0435\u043D\u044F
    \u043E\u043A\u0430\u0437\u0430\u043B\u0441\u044F \u0432 \u0441\u043C\u0435\u0440\u0442\u0435\u043B\u044C\u043D\u043E\u0439
    \u043B\u043E\u0432\u0443\u0448\u043A\u0435! \u0415\u0433\u043E \u043C\u0430\u043B\u0435\u043D\u044C\u043A\u043E\u0435
    \u0442\u0435\u043B\u043E \u0437\u0430\u0441\u0442\u0440\u044F\u043B\u043E \u0432
    \u0430\u0432\u0442\u043E\u043C\u043E\u0431\u0438\u043B\u044C\u043D\u043E\u0439
    \u0448\u0438\u043D\u0435, \u043A\u0430\u0436\u0434\u044B\u0439 \u0432\u0434\u043E\u0445
    \u2014 \u0431\u043E\u0440\u044C\u0431\u0430 \u0437\u0430 \u0436\u0438\u0437\u043D\u044C!"
  OnMinigameStart:
    m_PersistentCalls:
      m_Calls: []
  OnMinigameComplete:
    m_PersistentCalls:
      m_Calls: []
  OnFlyAway:
    m_PersistentCalls:
